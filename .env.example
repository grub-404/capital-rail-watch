# Copy this file to `.env` in the same folder (repository root) and add your key.
# See https://developer.wmata.com/
WMATA_KEY=

# HTTP port for python backend/server.py (default 5555)
# PORT=5555

# How often the server fetches Amtrak, MARC, VRE, Metro and upserts SQLite (seconds, min 5)
# INGEST_INTERVAL_SEC=30

# ── Ticker (ticker.html / tracker.html) — all optional; defaults shown
# TICKER_WINDOW_MINUTES=60
# TICKER_SPEED_PX_S=80
# TICKER_START_DWELL_MS=2200
# TICKER_END_DWELL_MS=900
# TICKER_FACT_DWELL_MS=7000
# TICKER_LABEL_ANIM_MS=360
# TICKER_REFRESH_MS=60000
# Set TICKER_REFRESH_MS=0 to disable periodic refresh (full cycle still reloads data).

# ── Vision (slice 0+; inference and screenshots — see README + vision/PLAN.md)
# YOLO weights (.pt). Empty = Ultralytics default COCO model yolov8n.pt (auto-download).
# VISION_MODEL_PATH=
# Confidence threshold for detections (0–1)
# VISION_CONF_THRESHOLD=0.5
# Where to write PNG + JSON sidecars when screenshot saving is enabled
# VISION_SCREENSHOT_DIR=data/vision_screenshots
# Approx. seconds between YOLO frames on video (vid_stride ≈ fps × this). 0 = every frame.
# VISION_VIDEO_SAMPLE_INTERVAL_SEC=1.0
# Min **video timeline** seconds between screenshots in the same file (spread along a pass)
# VISION_SCREENSHOT_MIN_VIDEO_SEC=6.0
# Optional min **wall-clock** seconds between screenshots per clip (0 = off)
# VISION_SCREENSHOT_MIN_INTERVAL_SEC=0
# yt-dlp clip output root (default data/clips); CSV manifest is data/clips/manifest.csv
# YTDLP_OUTPUT_DIR=data/clips
